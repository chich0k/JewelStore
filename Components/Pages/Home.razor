@page "/"

<PageTitle>Главная — JewelStore</PageTitle>

<div class="text-center py-5 my-5">
    <div class="js-ornament mb-4">◆ ◆ ◆</div>
    <h1 class="display-1 fw-light text-js mb-2" style="letter-spacing: 8px;">JEWELSTORE</h1>
    <p class="fs-5 text-muted fst-italic mb-5">Эксклюзивные украшения для особых моментов</p>
    <a class="btn js-btn-gold btn-lg px-5" href="/products">ОТКРЫТЬ КОЛЛЕКЦИЮ</a>
    <div class="js-ornament mt-5">◆ ◆ ◆</div>
</div>

<div class="row g-0 my-5">
    <div class="col-md-4 text-center py-5 border-end">
        <i class="bi bi-award fs-1 text-js"></i>
        <h6 class="mt-3 mb-1" style="letter-spacing: 3px;">СЕРТИФИЦИРОВАНО</h6>
        <small class="text-muted fst-italic">Каждое изделие имеет сертификат</small>
    </div>
    <div class="col-md-4 text-center py-5 border-end">
        <i class="bi bi-shield-lock fs-1 text-js"></i>
        <h6 class="mt-3 mb-1" style="letter-spacing: 3px;">БЕЗОПАСНОСТЬ</h6>
        <small class="text-muted fst-italic">Курьер с охраной и страховкой</small>
    </div>
    <div class="col-md-4 text-center py-5">
        <i class="bi bi-tools fs-1 text-js"></i>
        <h6 class="mt-3 mb-1" style="letter-spacing: 3px;">ГРАВИРОВКА</h6>
        <small class="text-muted fst-italic">Бесплатно к любому украшению</small>
    </div>
</div>